rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones helper ─────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuth() && request.auth.token.superAdmin == true;
    }
    function belongsToTenant(tenantId) {
      return isAuth() && request.auth.token.tenantId == tenantId;
    }
    function hasRole(tenantId, roles) {
      return belongsToTenant(tenantId) &&
        request.auth.token.role in roles;
    }
    function isAdmin(tenantId) {
      return hasRole(tenantId, ['admin']) || isSuperAdmin();
    }
    function isDoctor(tenantId) {
      return hasRole(tenantId, ['admin', 'doctor']) || isSuperAdmin();
    }
    function isStaff(tenantId) {
      return hasRole(tenantId, ['admin', 'doctor', 'recepcion']) || isSuperAdmin();
    }
    function isPaciente(tenantId) {
      return hasRole(tenantId, ['paciente']);
    }
    // Validar que no se inyecten campos peligrosos
    function noMaliciousFields() {
      return !('__proto__' in request.resource.data) &&
             !('constructor' in request.resource.data);
    }
    // Limitar tamaño de texto (anti DDoS)
    function textMaxLen(field, maxLen) {
      return !(field in request.resource.data) ||
        request.resource.data[field].size() <= maxLen;
    }

    // ── Tenants ──────────────────────────────────────────
    match /tenants/{tenantId} {
      // Solo superAdmin puede crear/borrar tenants
      allow create, delete: if isSuperAdmin();
      // Staff del tenant puede leer su propio tenant
      allow read: if isStaff(tenantId) || isSuperAdmin()
                  || isPaciente(tenantId); // pacientes leen nombre/config
      // Solo admin puede actualizar la config del tenant
      allow update: if isAdmin(tenantId);

      // ── Pacientes ──────────────────────────────────────
      match /pacientes/{pacienteId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin()
                      || (isPaciente(tenantId) &&
                          resource.data.email == request.auth.token.email);
        allow create: if isStaff(tenantId) || isSuperAdmin()
                      || request.auth != null; // registro online autenticado
        allow update: if isDoctor(tenantId) || isSuperAdmin()
                      || (isPaciente(tenantId) &&
                          resource.data.email == request.auth.token.email &&
                          // Paciente solo puede actualizar campos no médicos
                          !('alergias' in request.resource.data) &&
                          !('enfermedadesCronicas' in request.resource.data));
        allow delete: if isSuperAdmin();

        // Sub-colecciones del paciente
        match /documentos/{docId} {
          allow read:   if isStaff(tenantId) || isSuperAdmin()
                        || (isPaciente(tenantId) &&
                            get(/databases/$(database)/documents/tenants/$(tenantId)/pacientes/$(pacienteId)).data.email
                            == request.auth.token.email);
          allow create: if isDoctor(tenantId) || isSuperAdmin();
          allow update, delete: if isDoctor(tenantId) || isSuperAdmin();
        }
        match /vitales/{vitalId} {
          allow read, write: if isDoctor(tenantId) || isSuperAdmin();
        }
        match /medicamentos/{medId} {
          allow read:   if isStaff(tenantId) || isSuperAdmin()
                        || isPaciente(tenantId);
          allow write:  if isDoctor(tenantId) || isSuperAdmin();
        }
      }

      // ── Citas ──────────────────────────────────────────
      match /citas/{citaId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin()
                      || isPaciente(tenantId);
        allow create: if isStaff(tenantId) || isSuperAdmin()
                      || isPaciente(tenantId); // paciente puede agendar online
        // Paciente solo puede actualizar estatus (confirmar/cancelar)
        allow update: if isStaff(tenantId) || isSuperAdmin()
                      || (isPaciente(tenantId) &&
                          request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['estatus', 'historial']));
        allow delete: if isAdmin(tenantId) || isSuperAdmin();
      }

      // ── Consultas ──────────────────────────────────────
      match /consultas/{consultaId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin();
        allow create: if isDoctor(tenantId) || isSuperAdmin();
        allow update: if isDoctor(tenantId) || isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // ── Recetas ────────────────────────────────────────
      match /recetas/{recetaId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin()
                      || isPaciente(tenantId);
        allow create: if isDoctor(tenantId) || isSuperAdmin();
        allow update: if isDoctor(tenantId) || isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // ── Cobros ─────────────────────────────────────────
      match /cobros/{cobroId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin()
                      || isPaciente(tenantId);
        allow create: if isStaff(tenantId) || isSuperAdmin();
        allow update: if isStaff(tenantId) || isSuperAdmin()
                      || (isPaciente(tenantId) &&
                          // Paciente solo puede marcar como pagado online
                          request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['estadoPago','metodoPago','fechaPagoOnline']));
        allow delete: if isAdmin(tenantId) || isSuperAdmin();
      }

      // ── Facturas ───────────────────────────────────────
      match /facturas/{facturaId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin()
                      || isPaciente(tenantId);
        allow create: if isAdmin(tenantId) || isSuperAdmin();
        allow update: if isAdmin(tenantId) || isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // ── Usuarios del tenant ────────────────────────────
      match /usuarios/{usuarioId} {
        allow read:   if isAdmin(tenantId) || isSuperAdmin();
        allow create: if isAdmin(tenantId) || isSuperAdmin();
        allow update: if isAdmin(tenantId) || isSuperAdmin();
        allow delete: if isAdmin(tenantId) || isSuperAdmin();
      }

      // ── Encuestas ──────────────────────────────────────
      match /encuestas/{encuestaId} {
        allow read:   if isStaff(tenantId) || isSuperAdmin();
        // Escritura pública para el quiosco de recepción (sin login)
        allow create: if noMaliciousFields()
                      && textMaxLen('comentario', 1000);
        allow update, delete: if isAdmin(tenantId) || isSuperAdmin();
      }
    }

    // ── Bloquear todo lo demás ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
